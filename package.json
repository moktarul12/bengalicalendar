{
  "name": "bengali-english-calendar",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:dev": "eas build -p android --profile development",
    "build:preview": "eas build -p android --profile preview",
    "build:prod": "eas build -p android --profile production",
    "build:ios": "eas build -p ios --profile production",
    "submit": "eas submit -p android --latest",
    "update": "eas update --branch production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "expo": "~54.0.33",
    "expo-clipboard": "~7.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.21.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.12.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@types/react": "~18.3.0",
    "sharp": "^0.34.5",
    "typescript": "~5.3.0"
  },
  "private": true
}