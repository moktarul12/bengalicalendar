{
  "expo": {
    "name": "Bengali Calendar",
    "slug": "bengali-english-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E63946"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bengalicalendar.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Bengali Calendar"
      }
    },
    "android": {
      "package": "com.bengalienglishcalendar",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E63946"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E63946",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E63946",
          "sounds": []
        }
      ],
    ],
    "extra": {
      "eas": {
        "projectId": "ca870a0a-cbd9-48ca-a9cf-0622a2c01240"
      }
    },
    "owner": "moktarul",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bengali-english-calendar"
    }
  }
}
